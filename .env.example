# ============================================================
# DeadlineZero – Environment Configuration Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------------
# Google Gemini API  (required)
# Get your key at: https://aistudio.google.com/apikey
# ------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (swap to upgrade/downgrade without code changes)
# Options: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash

# ------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------
APP_NAME=DeadlineZero
APP_ENV=development          # development | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./deadlinezero.db

# ------------------------------------------------------------------
# Security
# ------------------------------------------------------------------
SECRET_KEY=change_me_to_a_random_256bit_secret
ALLOWED_ORIGINS=*            # Comma-separated in production: https://myapp.com

# ------------------------------------------------------------------
# Scheduler (background deadline monitor)
# ------------------------------------------------------------------
SCHEDULER_ENABLED=true
DEADLINE_CHECK_INTERVAL_MINUTES=30

# ------------------------------------------------------------------
# AI Agent Tuning
# ------------------------------------------------------------------
AGENT_MAX_ITERATIONS=10          # Max ReAct loop iterations per request
AGENT_TEMPERATURE=0.4            # Gemini generation temperature (0.0–1.0)
AGENT_MAX_OUTPUT_TOKENS=2048
